{
  "name": "regents-cli-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm --filter @regentslabs/cli build",
    "typecheck": "pnpm --filter @regentslabs/cli typecheck",
    "lint": "pnpm --filter @regentslabs/cli lint",
    "test": "pnpm --filter @regentslabs/cli test",
    "generate:openapi": "node scripts/generate-openapi-types.mjs",
    "generate:cli-command-metadata": "node scripts/generate-cli-command-metadata.mjs",
    "check:shared-services-contract": "node scripts/check-shared-services-contract.mjs",
    "check:contract-inputs": "node scripts/check-contract-inputs.mjs",
    "check:openapi": "pnpm check:contract-inputs && pnpm check:shared-services-contract && node scripts/check-openapi-types.mjs",
    "check:openapi:platform": "node scripts/check-platform-openapi-types.mjs",
    "check:cli-contract": "pnpm check:contract-inputs && node scripts/check-cli-contract.mjs",
    "check:pack-cli-contents": "node scripts/check-packed-cli-package.mjs",
    "test:integration": "pnpm --filter @regentslabs/cli --if-present test:integration",
    "pack:cli": "bash -lc 'mkdir -p .packed && cd packages/regents-cli && pnpm pack --pack-destination ../../.packed'",
    "test:pack-smoke": "bash scripts/packed-install-smoke.sh",
    "release:cli": "bash scripts/release-cli.sh",
    "clean": "pnpm --filter @regentslabs/cli clean"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "yaml": "^2.8.1"
  }
}
